# Auto detect text files and perform LF normalization
* text=auto

# Explicitly declare text files
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.css text eol=lf
*.xml text eol=lf
*.xhtml text eol=lf
*.opf text eol=lf
*.ncx text eol=lf

# Binary files
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.webp binary
*.bmp binary
*.svg binary
*.epub binary
*.zip binary
